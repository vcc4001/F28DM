    <question id="4">
        <answer>2500324</answer>
        <sql>
          <![CDATA[
            SELECT ac.actorid
            FROM imdb.actors ac
            JOIN imdb.movies2actors m2a
            ON ac.actorid = m2a.actorid
            WHERE m2a.movieid IN (
              SELECT m2a.movieid
              FROM imdb.actors AS ac
              INNER JOIN imdb.movies2actors AS m2a
              ON ac.actorid = m2a.actorid
              WHERE ac.name = 'Hanks, Tom')
            AND ac.name <> 'Hanks, Tom'
            GROUP BY ac.actorid
            ORDER BY COUNT(ac.actorid) DESC
            LIMIT 1;
           ]]>
        </sql>
    </question>

    <question id="5">
        <answer>3</answer>
        <sql>
          <![CDATA[ 
            SELECT COUNT(*)
            FROM (
            SELECT m1.actorid, m2.actorid, COUNT(*)
            FROM imdb.movies2actors m1
            JOIN imdb.movies2actors m2
              ON m1.movieid = m2.movieid
            WHERE m1.actorid < m2.actorid
            GROUP BY m1.actorid, m2.actorid
            HAVING COUNT(*) > 10);
           ]]>
        </sql>
    </question>

    <question id="6">
        <answer>1930</answer>
        <sql>
          <![CDATA[
            SELECT (mv.year / 10) * 10 AS decade
            FROM imdb.movies mv
            JOIN imdb.ratings rt ON mv.movieid = rt.movieid
            GROUP BY (mv.year / 10) * 10
            ORDER BY AVG(rt.rank::float) DESC
            LIMIT 1; 
            ]]>
        </sql>
    </question>

